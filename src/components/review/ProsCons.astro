---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
  <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5">
    <h3 class="font-bold text-emerald-800 mb-3 flex items-center gap-2">
      <span class="text-emerald-600">&#10003;</span> Avantages
    </h3>
    <ul class="space-y-2">
      {pros.map((pro) => (
        <li class="flex items-start gap-2 text-sm text-slate-700">
          <span class="text-emerald-500 mt-0.5 flex-shrink-0">+</span>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>
  <div class="bg-red-50 border border-red-200 rounded-xl p-5">
    <h3 class="font-bold text-red-800 mb-3 flex items-center gap-2">
      <span class="text-red-600">&#10007;</span> Inconvénients
    </h3>
    <ul class="space-y-2">
      {cons.map((con) => (
        <li class="flex items-start gap-2 text-sm text-slate-700">
          <span class="text-red-500 mt-0.5 flex-shrink-0">−</span>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
